// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  fullName     String
  email        String    @unique
  password     String
  phoneNumber  String
  organizationName String?
  role         Role
  subType      String
  createdAt    DateTime  @default(now())
  listings     Listing[] @relation("DonorListings")
  claimedListings Listing[] @relation("RecipientListings")
}

model Listing {
  id             Int       @id @default(autoincrement())
  title          String
  description    String
  quantity       String
  pickupDeadline DateTime
  photoUrl       String?
  classification FoodType
  status         Status    @default(available)
  createdAt      DateTime  @default(now())
  donor          User      @relation("DonorListings", fields: [donorId], references: [id])
  donorId        Int
  recipient      User?     @relation("RecipientListings", fields: [recipientId], references: [id])
  recipientId    Int?
}

enum Role {
  donor
  recipient
  admin
}

enum FoodType {
  edible
  inedible
}

enum Status {
  available
  claimed
  expired
}
